{
  "$schema": "https://vercel.sh",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://orakitech-backend.onrender.com"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://orakitech-backend.onrender.com*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
